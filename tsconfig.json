{
  "extends": "@tsconfig/node20/tsconfig.json",
  "include": ["src/**/*"],
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "useDefineForClassFields": false,
    "strict": true,
    "rootDir": "src",
    "outDir": "com.aaronholt.claude-usage.sdPlugin/bin"
  }
}
